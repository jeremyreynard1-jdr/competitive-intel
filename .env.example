# Tavily API — web search for all research queries
# Get your key at https://tavily.com (free tier: 1,000 searches/month)
TAVILY_API_KEY=tvly-your-key-here

# Anthropic API — Claude for analysis and synthesis
# Named CLAUDE_API_KEY to avoid conflict with Claude Code's ANTHROPIC_API_KEY env var
# Get your key at https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-your-key-here

# Port for local development
PORT=3847
